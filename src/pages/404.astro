---
const copy = {
  it: {
    cta: 'Torna alla home',
  },
  en: {
    cta: 'Back to home',
  },
};
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 | Halo Tournament Generator</title>
    <style>
      :root {
        color-scheme: dark;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        font-family: "Oxanium", system-ui, sans-serif;
        color: #fff;
        background: linear-gradient(180deg, #071633 0%, #030d22 100%);
      }

      .shell {
        width: min(100%, 880px);
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .visual {
        min-height: min(72vh, 780px);
        border-radius: 28px;
        border: 1px solid rgba(120, 194, 255, 0.2);
        background:
          linear-gradient(180deg, rgba(2, 11, 31, 0.12) 0%, rgba(2, 11, 31, 0.34) 100%),
          url("/404%20Page.jpg") center / cover no-repeat;
        box-shadow:
          0 0 48px rgba(46, 131, 255, 0.14),
          inset 0 1px 0 rgba(255, 255, 255, 0.08);
        position: relative;
        overflow: hidden;
      }

      .actions {
        display: flex;
        justify-content: center;
        width: 100%;
      }

      a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 50px;
        min-width: 220px;
        padding: 0 22px;
        border-radius: 16px;
        border: 1px solid rgba(255, 214, 140, 0.78);
        background:
          linear-gradient(180deg, rgba(255, 252, 244, 0.34) 0%, rgba(255, 247, 224, 0.28) 100%),
          linear-gradient(180deg, rgba(245, 180, 76, 0.78) 0%, rgba(180, 110, 22, 0.95) 100%);
        color: rgb(36, 19, 0);
        text-decoration: none;
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        box-shadow: 0 0 24px rgba(245, 180, 76, 0.18);
      }

      @media (max-width: 640px) {
        .shell {
          width: 100%;
        }

        .visual {
          min-height: 72vh;
          border-radius: 18px;
        }

        .actions {
          width: 100%;
        }

        a {
          min-width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <section class="visual" aria-label="404 page artwork"></section>
      <div class="actions">
        <a href="/">{copy.it.cta}</a>
      </div>
    </main>
  </body>
</html>
